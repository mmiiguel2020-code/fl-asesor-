{
  "name": "fl-studio-advisor-desktop",
  "version": "1.0.0",
  "type": "module",
  "description": "FL Studio Resource Optimization Advisor - Desktop Application",
  "main": "dist/electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && vite build --config vite.electron.config.ts",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "dotenv": "^17.2.3",
    "motion": "^12.23.24",
    "electron-squirrel-startup": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/electron": "^1.6.10",
    "autoprefixer": "^10.4.21",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.5",
    "better-sqlite3": "^11.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "esbuild": "^0.25.0"
  },
  "build": {
    "appId": "com.flstudio.advisor",
    "productName": "FL Studio Advisor",
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FL Studio Advisor"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "AudioVideo"
    }
  }
}
